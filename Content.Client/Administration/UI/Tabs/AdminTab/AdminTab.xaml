<Control
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    xmlns:at="clr-namespace:Content.Client.Administration.UI.Tabs.AdminTab"
    xmlns:adminbus="clr-namespace:Content.Client.Administration.UI.Tabs.AdminbusTab"
    xmlns:atmos="clr-namespace:Content.Client.Administration.UI.Tabs.AtmosTab"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    xmlns:objects="clr-namespace:Content.Client.Administration.UI.Tabs.ObjectsTab"
    xmlns:player="clr-namespace:Content.Client.Administration.UI.Tabs.PlayerTab"
    xmlns:tabs="clr-namespace:Content.Client.Administration.UI.Tabs"
    xmlns:panic="clr-namespace:Content.Client.Administration.UI.Tabs.PanicBunkerTab"
    Margin="6"
    MinSize="480 300">
    <TabContainer Name="SubTabs" HorizontalExpand="True" VerticalExpand="True">

        <!-- ===== Quick Tools ===== -->
        <ScrollContainer HorizontalExpand="True" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" SeparationOverride="6" Margin="6">
                <Label Text="{Loc admin-tools-section-quick-desc}" StyleClasses="LabelSubText" />
                <GridContainer Columns="4" HorizontalExpand="True">
                    <cc:CommandButton Command="banpanel" Text="{Loc admin-player-actions-window-ban}" />
                    <cc:CommandButton Command="aghost" Text="{Loc admin-player-actions-window-admin-ghost}" />
                    <cc:CommandButton Command="permissions" Text="{Loc admin-player-actions-window-permissions}" />
                    <cc:CommandButton Command="announceui" Text="{Loc admin-player-actions-window-announce}" />
                    <cc:UICommandButton Command="callshuttle" Text="{Loc admin-player-actions-window-shuttle}" WindowType="{x:Type at:AdminShuttleWindow}" />
                    <cc:CommandButton Command="adminlogs" Text="{Loc admin-player-actions-window-admin-logs}" />
                    <cc:CommandButton Command="faxui" Text="{Loc admin-player-actions-window-admin-fax}" />
                    <cc:CommandButton Command="achatwindow" Text="{Loc admin-player-actions-window-admin-chat}" />
                    <cc:CommandButton Command="timetransferpanel" Text="{Loc admin-player-actions-window-time-transfer}" />
                </GridContainer>

                <cc:HSeparator Margin="0 8 0 4" />

                <Collapsible>
                    <CollapsibleHeading Title="{Loc admin-menu-round-tab}" />
                    <CollapsibleBody Margin="16 4 0 8">
                        <BoxContainer Orientation="Vertical" SeparationOverride="6">
                            <Label Text="{Loc admin-menu-round-desc}" StyleClasses="LabelSubText" />
                            <tabs:RoundTab />
                        </BoxContainer>
                    </CollapsibleBody>
                </Collapsible>

                <Collapsible>
                    <CollapsibleHeading Title="{Loc admin-menu-server-tab}" />
                    <CollapsibleBody Margin="16 4 0 8">
                        <BoxContainer Orientation="Vertical" SeparationOverride="6">
                            <Label Text="{Loc admin-menu-server-desc}" StyleClasses="LabelSubText" />
                            <tabs:ServerTab />
                        </BoxContainer>
                    </CollapsibleBody>
                </Collapsible>

                <Collapsible>
                    <CollapsibleHeading Title="{Loc admin-menu-panic-bunker-tab}" />
                    <CollapsibleBody Margin="16 4 0 8">
                        <BoxContainer Orientation="Vertical" SeparationOverride="6">
                            <Label Text="{Loc admin-menu-panic-bunker-desc}" StyleClasses="LabelSubText" />
                            <panic:PanicBunkerTab Name="PanicBunkerControl" Access="Public" />
                        </BoxContainer>
                    </CollapsibleBody>
                </Collapsible>

                <Collapsible>
                    <CollapsibleHeading Title="{Loc admin-menu-world-tab}" />
                    <CollapsibleBody Margin="16 4 0 8">
                        <BoxContainer Orientation="Vertical" SeparationOverride="6">
                            <Label Text="{Loc admin-menu-world-desc}" StyleClasses="LabelSubText" />
                            <adminbus:AdminbusTab />
                        </BoxContainer>
                    </CollapsibleBody>
                </Collapsible>

                <Collapsible>
                    <CollapsibleHeading Title="{Loc admin-menu-atmos-tab}" />
                    <CollapsibleBody Margin="16 4 0 8">
                        <BoxContainer Orientation="Vertical" SeparationOverride="6">
                            <Label Text="{Loc admin-menu-atmos-desc}" StyleClasses="LabelSubText" />
                            <atmos:AtmosTab />
                        </BoxContainer>
                    </CollapsibleBody>
                </Collapsible>
            </BoxContainer>
        </ScrollContainer>

        <!-- ===== Votes ===== -->
        <ScrollContainer HorizontalExpand="True" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" SeparationOverride="6" Margin="6">
                <Label Text="{Loc admin-tools-section-votes-desc}" StyleClasses="LabelSubText" />
                <GridContainer Columns="3" HorizontalExpand="True">
                    <controls:ConfirmButton Name="CreateRestartVoteButton"
                                            Text="{Loc admin-tools-vote-restart}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            ToolTip="{Loc admin-tools-vote-restart-tooltip}" />
                    <controls:ConfirmButton Name="CreatePresetVoteButton"
                                            Text="{Loc admin-tools-vote-preset}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            ToolTip="{Loc admin-tools-vote-preset-tooltip}" />
                    <controls:ConfirmButton Name="CreateMapVoteButton"
                                            Text="{Loc admin-tools-vote-map}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            ToolTip="{Loc admin-tools-vote-map-tooltip}" />
                </GridContainer>

                <cc:HSeparator Margin="0 8 0 4" />
                <Label Text="{Loc admin-tools-subsection-custom-vote}" />
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Label Text="{Loc admin-tools-custom-vote-title}" MinWidth="120" />
                    <LineEdit Name="CustomVoteTitle" HorizontalExpand="True" PlaceHolder="{Loc admin-tools-custom-vote-title-placeholder}" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Label Text="{Loc admin-tools-custom-vote-options}" MinWidth="120" />
                    <LineEdit Name="CustomVoteOptions" HorizontalExpand="True" PlaceHolder="{Loc admin-tools-custom-vote-options-placeholder}" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Button Name="CreateCustomVoteButton" Text="{Loc admin-tools-custom-vote-create}" />
                </BoxContainer>

                <cc:HSeparator Margin="0 8 0 4" />
                <Label Text="{Loc admin-tools-subsection-cancel-vote}" />
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Label Text="{Loc admin-tools-cancel-vote-id}" MinWidth="120" />
                    <LineEdit Name="CancelVoteId" HorizontalExpand="True" PlaceHolder="{Loc admin-tools-cancel-vote-id-placeholder}" />
                    <controls:ConfirmButton Name="CancelVoteButton"
                                            Text="{Loc admin-tools-cancel-vote}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            ToolTip="{Loc admin-tools-cancel-vote-tooltip}" />
                </BoxContainer>

                <cc:HSeparator Margin="0 8 0 4" />
                <Label Text="{Loc admin-tools-subsection-vote-audit}" />
                <Label Text="{Loc admin-tools-subsection-vote-audit-desc}" StyleClasses="LabelSubText" />
                <Button Name="VoteAuditOpenButton" Text="{Loc admin-tools-vote-audit-open}" ToolTip="{Loc admin-tools-vote-audit-open-tooltip}" />
            </BoxContainer>
        </ScrollContainer>

        <!-- ===== Ships ===== -->
        <ScrollContainer HorizontalExpand="True" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" SeparationOverride="6" Margin="6">
                <Label Text="{Loc admin-tools-section-ships-desc}" StyleClasses="LabelSubText" />
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Label Text="{Loc admin-tools-ship-deed-id}" MinWidth="140" />
                    <LineEdit Name="ShipDeedId" HorizontalExpand="True" PlaceHolder="{Loc admin-tools-ship-deed-id-placeholder}" />
                    <controls:ConfirmButton Name="SaveShipButton"
                                            Text="{Loc admin-tools-ship-save}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            ToolTip="{Loc admin-tools-ship-save-tooltip}" />
                </BoxContainer>
            </BoxContainer>
        </ScrollContainer>

        <!-- ===== AHelp (Auto-Reply + Triage) ===== -->
        <ScrollContainer HorizontalExpand="True" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" SeparationOverride="6" Margin="6">
                <Label Text="{Loc admin-tools-ahelp-shared-category-desc}" StyleClasses="LabelSubText" />
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Label Text="{Loc admin-tools-ahelp-category}" MinWidth="120" />
                    <OptionButton Name="AutoReplyCategory" HorizontalExpand="True" />
                    <Button Name="RefreshAhelpConfigButton" Text="{Loc admin-tools-ahelp-refresh}" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" SeparationOverride="10">
                    <Label Name="AutoReplyStateLabel" Text="{Loc admin-tools-ahelp-state-loading}" StyleClasses="LabelSubText" HorizontalExpand="True" />
                    <Label Name="TriageStateLabel" Text="{Loc admin-tools-triage-state-loading}" StyleClasses="LabelSubText" HorizontalExpand="True" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Label Text="{Loc admin-tools-ahelp-bot-name}" MinWidth="120" />
                    <LineEdit Name="AutoReplyBotName" HorizontalExpand="True" PlaceHolder="{Loc admin-tools-ahelp-bot-name-placeholder}" />
                    <Button Name="SaveAutoReplyBotNameButton" Text="{Loc admin-tools-ahelp-bot-name-save}" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Label Text="{Loc admin-tools-ahelp-new-category}" MinWidth="120" />
                    <LineEdit Name="AhelpCategoryName" HorizontalExpand="True" PlaceHolder="{Loc admin-tools-ahelp-new-category-placeholder}" />
                    <Button Name="AddCategoryButton" Text="{Loc admin-tools-ahelp-add-category}" />
                    <controls:ConfirmButton Name="RemoveCategoryButton"
                                            Text="{Loc admin-tools-ahelp-remove-category}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}" />
                </BoxContainer>

                <cc:HSeparator Margin="0 8 0 4" />

                <Label Text="{Loc admin-tools-section-ahelp}" />
                <Label Text="{Loc admin-tools-section-ahelp-desc}" StyleClasses="LabelSubText" />
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Button Name="AutoReplyEnableButton" Text="{Loc admin-tools-ahelp-enable}" StyleClasses="OpenRight" />
                    <controls:ConfirmButton Name="AutoReplyDisableButton"
                                            Text="{Loc admin-tools-ahelp-disable}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            StyleClasses="OpenLeft" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Label Name="AutoReplyRuleStateLabel" Text="{Loc admin-tools-ahelp-rule-state-loading}" StyleClasses="LabelSubText" HorizontalExpand="True" />
                    <Button Name="AutoReplyRuleEnableButton" Text="{Loc admin-tools-ahelp-rule-enable}" StyleClasses="OpenRight" />
                    <controls:ConfirmButton Name="AutoReplyRuleDisableButton"
                                            Text="{Loc admin-tools-ahelp-rule-disable}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            StyleClasses="OpenLeft" />
                </BoxContainer>
                <ItemList Name="AutoReplyTemplatesList" MinSize="220 120" />
                <BoxContainer Orientation="Vertical" SeparationOverride="4">
                    <Label Text="{Loc admin-tools-ahelp-template}" />
                    <PanelContainer MinHeight="96" HorizontalExpand="True">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#14171A" BorderThickness="1" BorderColor="#5A6572" />
                        </PanelContainer.PanelOverride>
                        <TextEdit Name="AutoReplyTemplate" MinHeight="72" HorizontalExpand="True" Margin="4" />
                    </PanelContainer>
                    <Label Text="{Loc admin-tools-ahelp-template-format}" StyleClasses="LabelSubText" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Button Name="AutoReplySaveButton" Text="{Loc admin-tools-ahelp-save}" />
                    <controls:ConfirmButton Name="AutoReplyResetButton"
                                            Text="{Loc admin-tools-ahelp-reset}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            ToolTip="{Loc admin-tools-ahelp-reset-tooltip}" />
                </BoxContainer>
                <Label Text="{Loc admin-tools-ahelp-note}" StyleClasses="LabelSubText" />

                <cc:HSeparator Margin="0 8 0 4" />

                <Label Text="{Loc admin-tools-section-triage}" />
                <Label Text="{Loc admin-tools-section-triage-desc}" StyleClasses="LabelSubText" />
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Button Name="TriageEnableButton" Text="{Loc admin-tools-triage-enable}" StyleClasses="OpenRight" />
                    <controls:ConfirmButton Name="TriageDisableButton"
                                            Text="{Loc admin-tools-triage-disable}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            StyleClasses="OpenLeft" />
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Label Name="TriageRuleStateLabel" Text="{Loc admin-tools-triage-rule-state-loading}" StyleClasses="LabelSubText" HorizontalExpand="True" />
                    <Button Name="TriageRuleEnableButton" Text="{Loc admin-tools-triage-rule-enable}" StyleClasses="OpenRight" />
                    <controls:ConfirmButton Name="TriageRuleDisableButton"
                                            Text="{Loc admin-tools-triage-rule-disable}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            StyleClasses="OpenLeft" />
                </BoxContainer>
                <ItemList Name="TriageRulesList" MinSize="220 120" />
                <BoxContainer Orientation="Vertical" SeparationOverride="4">
                    <Label Text="{Loc admin-tools-triage-keywords}" />
                    <PanelContainer MinHeight="96" HorizontalExpand="True">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#14171A" BorderThickness="1" BorderColor="#5A6572" />
                        </PanelContainer.PanelOverride>
                        <TextEdit Name="TriageKeywords" MinHeight="72" HorizontalExpand="True" Margin="4" />
                    </PanelContainer>
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Button Name="TriageSaveButton" Text="{Loc admin-tools-triage-save}" />
                    <controls:ConfirmButton Name="TriageResetButton"
                                            Text="{Loc admin-tools-triage-reset}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            ToolTip="{Loc admin-tools-triage-reset-tooltip}" />
                </BoxContainer>
                <Label Text="{Loc admin-tools-triage-note}" StyleClasses="LabelSubText" />

                <cc:HSeparator Margin="0 8 0 4" />

                <Label Text="{Loc admin-tools-section-panic}" />
                <Label Text="{Loc admin-tools-section-panic-desc}" StyleClasses="LabelSubText" />
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Button Name="PanicEnableButton" Text="{Loc admin-tools-panic-enable}" StyleClasses="OpenRight" />
                    <controls:ConfirmButton Name="PanicDisableButton"
                                            Text="{Loc admin-tools-panic-disable}"
                                            ConfirmationText="{Loc admin-player-actions-confirm}"
                                            StyleClasses="OpenLeft" />
                </BoxContainer>
                <Label Name="PanicStateLabel" Text="{Loc admin-tools-panic-state-loading}" StyleClasses="LabelSubText" HorizontalExpand="True" />
                <BoxContainer Orientation="Vertical" SeparationOverride="4">
                    <Label Text="{Loc admin-tools-panic-template}" />
                    <PanelContainer MinHeight="96" HorizontalExpand="True">
                        <PanelContainer.PanelOverride>
                            <gfx:StyleBoxFlat BackgroundColor="#14171A" BorderThickness="1" BorderColor="#5A6572" />
                        </PanelContainer.PanelOverride>
                        <TextEdit Name="PanicTemplate" MinHeight="72" HorizontalExpand="True" Margin="4" />
                    </PanelContainer>
                </BoxContainer>
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Button Name="PanicSaveButton" Text="{Loc admin-tools-panic-save}" />
                </BoxContainer>
                <Label Text="{Loc admin-tools-panic-note}" StyleClasses="LabelSubText" />
            </BoxContainer>
        </ScrollContainer>

        <!-- ===== Macros (Saved Commands) ===== -->
        <ScrollContainer HorizontalExpand="True" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" SeparationOverride="6" Margin="6">
                <Label Text="{Loc admin-tools-section-saved-desc}" StyleClasses="LabelSubText" />
                <BoxContainer Orientation="Horizontal" SeparationOverride="8" HorizontalExpand="True" VerticalExpand="True">
                    <ItemList Name="SavedCommandsList" MinSize="220 160" VerticalExpand="True" SelectMode="Single" />
                    <BoxContainer Orientation="Vertical" SeparationOverride="6" HorizontalExpand="True">
                        <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                            <Label Text="{Loc admin-tools-saved-name}" MinWidth="120" />
                            <LineEdit Name="SavedCommandName" HorizontalExpand="True" PlaceHolder="{Loc admin-tools-saved-name-placeholder}" />
                        </BoxContainer>
                        <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                            <Label Text="{Loc admin-tools-saved-command}" MinWidth="120" />
                            <PanelContainer MinHeight="96" HorizontalExpand="True">
                                <PanelContainer.PanelOverride>
                                    <gfx:StyleBoxFlat BackgroundColor="#14171A" BorderThickness="1" BorderColor="#5A6572" />
                                </PanelContainer.PanelOverride>
                                <TextEdit Name="SavedCommandText" MinHeight="72" HorizontalExpand="True" Margin="4" />
                            </PanelContainer>
                        </BoxContainer>
                        <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                            <Button Name="SavedCommandRunButton"
                                    Text="{Loc admin-tools-saved-run}"
                                    ToolTip="{Loc admin-tools-saved-run-tooltip}" />
                            <Button Name="SavedCommandSaveButton"
                                    Text="{Loc admin-tools-saved-save}"
                                    ToolTip="{Loc admin-tools-saved-save-tooltip}" />
                            <Button Name="SharedMacrosButton"
                                Text="{Loc admin-tools-shared-macros-open}"
                                ToolTip="{Loc admin-tools-shared-macros-open-tooltip}" />
                            <Control HorizontalExpand="True" />
                            <controls:ConfirmButton Name="SavedCommandDeleteButton"
                                                    Text="{Loc admin-tools-saved-delete}"
                                                    ConfirmationText="{Loc admin-player-actions-confirm}"
                                                    ToolTip="{Loc admin-tools-saved-delete-tooltip}" />
                        </BoxContainer>
                        <Label Text="{Loc admin-tools-saved-note}" StyleClasses="LabelSubText" />
                    </BoxContainer>
                </BoxContainer>
            </BoxContainer>
        </ScrollContainer>

        <!-- ===== Players ===== -->
        <BoxContainer Orientation="Vertical" SeparationOverride="6" Margin="6" HorizontalExpand="True" VerticalExpand="True">
            <Label Text="{Loc admin-menu-players-desc}" StyleClasses="LabelSubText" />
            <player:PlayerTab Name="PlayerTabControl" Access="Public" VerticalExpand="True" />
        </BoxContainer>

        <!-- ===== Objects ===== -->
        <BoxContainer Orientation="Vertical" SeparationOverride="6" Margin="6" HorizontalExpand="True" VerticalExpand="True">
            <Label Text="{Loc admin-menu-objects-desc}" StyleClasses="LabelSubText" />
            <objects:ObjectsTab Name="ObjectsTabControl" Access="Public" VerticalExpand="True" />
        </BoxContainer>

        <!-- ===== Statistics ===== -->
        <ScrollContainer HorizontalExpand="True" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" SeparationOverride="6" Margin="6">
                <Label Text="{Loc admin-tools-section-statistics-desc}" StyleClasses="LabelSubText" />
                <BoxContainer Orientation="Horizontal" SeparationOverride="6">
                    <Button Name="RefreshStatisticsButton" Text="{Loc admin-tools-statistics-refresh}" />
                    <Label Name="StatisticsUpdatedLabel"
                           Text="{Loc admin-tools-statistics-updated-never}"
                           StyleClasses="LabelSubText"
                           HorizontalExpand="True" />
                </BoxContainer>

                <cc:HSeparator Margin="0 8 0 4" />

                <Label Name="StatisticsOnlineLabel" Text="{Loc admin-tools-statistics-online-loading}" />
                <Label Name="StatisticsLagLabel" Text="{Loc admin-tools-statistics-lag-loading}" />
                <Label Name="StatisticsRoundLabel" Text="{Loc admin-tools-statistics-round-loading}" />
                <Label Name="StatisticsUptimeLabel" Text="{Loc admin-tools-statistics-uptime-loading}" />

                <cc:HSeparator Margin="0 8 0 4" />

                <Label Text="{Loc admin-tools-statistics-roles-header}" />
                <LineEdit Name="RolesSearchBox" PlaceHolder="{Loc admin-tools-statistics-roles-search}" />
                <ItemList Name="StatisticsRolesList" MinSize="220 140" />

                <Label Text="{Loc admin-tools-statistics-antags-header}" />
                <ItemList Name="StatisticsAntagsList" MinSize="220 100" />
            </BoxContainer>
        </ScrollContainer>

    </TabContainer>
</Control>
